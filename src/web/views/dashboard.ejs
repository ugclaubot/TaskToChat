<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TaskToChat</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            surface: '#ffffff',
            page: '#f5f5f4',
            accent: '#18181b',
            muted: '#a1a1aa',
            subtle: '#e4e4e7',
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { font-family: 'Inter', system-ui, sans-serif; }
    .task-row { transition: background 0.1s; }
    .task-row:hover { background: #fafaf9; }
    .task-row:hover .hover-show { opacity: 1; }
    .hover-show { opacity: 0; transition: opacity 0.12s; }
    @media (max-width: 640px) { .hover-show { opacity: 1; } }
    .pri-high { border-left: 3px solid #ef4444; }
    .pri-medium { border-left: 3px solid #f59e0b; }
    .pri-low { border-left: 3px solid #22c55e; }
    .dot-high { background: #ef4444; }
    .dot-medium { background: #f59e0b; }
    .dot-low { background: #22c55e; }
    .add-row { display: none; }
    .add-row.open { display: flex; }
    .filter-panel { max-height: 0; overflow: hidden; transition: max-height 0.2s ease; }
    .filter-panel.open { max-height: 200px; }
    .toast { animation: slideIn 0.3s ease, fadeOut 0.3s ease 3s forwards; }
    @keyframes slideIn { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @keyframes fadeOut { to { opacity: 0; pointer-events: none; } }
    .check-btn { transition: all 0.15s; }
    .check-btn:hover { border-color: #22c55e; background: #f0fdf4; color: #22c55e; }
    .send-btn { transition: all 0.15s; }
    .send-btn:hover { background: #2563eb; color: white; }
  </style>
</head>
<body class="bg-page min-h-screen">

  <!-- Toast notification -->
  <% if (msg) { %>
  <div class="toast fixed top-4 left-1/2 -translate-x-1/2 z-50 bg-accent text-white text-sm px-4 py-2 rounded-lg shadow-lg">
    <%= msg %>
  </div>
  <% } %>

  <!-- Header -->
  <div class="max-w-2xl mx-auto px-4 pt-8 pb-3">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-accent tracking-tight">TaskToChat</h1>
        <div class="flex items-center gap-3 mt-1 text-xs text-muted">
          <span><%= stats.pending + stats.in_progress + stats.overdue %> open</span>
          <span class="text-subtle">·</span>
          <% if (stats.overdue > 0) { %><span class="text-red-500"><%= stats.overdue %> overdue</span><span class="text-subtle">·</span><% } %>
          <span><%= stats.completed %> done</span>
          <span class="text-subtle">·</span>
          <span class="text-emerald-600"><%= stats.completion_rate %>%</span>
        </div>
      </div>
      <button onclick="document.getElementById('filters').classList.toggle('open')"
        class="text-xs text-muted hover:text-accent border border-subtle rounded-lg px-3 py-1.5 transition hover:border-zinc-400">
        Filters
      </button>
    </div>

    <!-- Filters -->
    <div id="filters" class="filter-panel <%= (filters.status || filters.employee || filters.from || filters.to) ? 'open' : '' %>">
      <form method="GET" action="/" class="flex flex-wrap gap-2 items-center mt-3 pt-3 border-t border-subtle">
        <select name="status" class="text-xs border border-subtle rounded-lg px-2.5 py-1.5 bg-surface text-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-300">
          <option value="">All status</option>
          <option value="pending" <%- filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="in_progress" <%- filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
          <option value="overdue" <%- filters.status === 'overdue' ? 'selected' : '' %>>Overdue</option>
          <option value="completed" <%- filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
        <select name="employee" class="text-xs border border-subtle rounded-lg px-2.5 py-1.5 bg-surface text-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-300">
          <option value="">All people</option>
          <% employees.forEach(e => { %>
          <option value="<%= e.id %>" <%- filters.employee == e.id ? 'selected' : '' %>><%= e.name %></option>
          <% }) %>
        </select>
        <input type="date" name="from" value="<%= filters.from || '' %>" class="text-xs border border-subtle rounded-lg px-2.5 py-1.5 text-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-300" />
        <input type="date" name="to" value="<%= filters.to || '' %>" class="text-xs border border-subtle rounded-lg px-2.5 py-1.5 text-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-300" />
        <button type="submit" class="text-xs bg-accent text-white px-3 py-1.5 rounded-lg font-medium hover:bg-zinc-800 transition">Apply</button>
        <a href="/" class="text-xs text-muted hover:text-accent transition">Reset</a>
      </form>
    </div>
  </div>

  <!-- Task sections -->
  <div class="max-w-2xl mx-auto px-4 pb-8">

    <% if (tasks.length === 0) { %>
    <div class="bg-surface rounded-2xl border border-subtle px-4 py-10 text-center">
      <div class="text-3xl mb-2">✨</div>
      <p class="text-sm text-muted">No tasks yet — add one below</p>
    </div>
    <% } else { %>

    <%
      const activeTasks = tasks.filter(t => t.status !== 'completed');
      const completedTasks = tasks.filter(t => t.status === 'completed');

      const sections = [];
      const byEmployee = {};
      const unassignedByGroup = {};
      const unassignedNoGroup = [];

      for (const t of activeTasks) {
        if (t.employee_name) {
          if (!byEmployee[t.employee_name]) byEmployee[t.employee_name] = { tasks: [], employeeId: t.assigned_to };
          byEmployee[t.employee_name].tasks.push(t);
        } else if (t.group_chat_name) {
          if (!unassignedByGroup[t.group_chat_name]) unassignedByGroup[t.group_chat_name] = { tasks: [], groupChatId: t.group_chat_id, groupChatName: t.group_chat_name };
          unassignedByGroup[t.group_chat_name].tasks.push(t);
        } else {
          unassignedNoGroup.push(t);
        }
      }

      for (const [name, data] of Object.entries(byEmployee)) {
        sections.push({ key: 'emp-' + data.employeeId, label: name, icon: '👤', tasks: data.tasks, employeeId: data.employeeId, groupChatId: null, groupChatName: null, type: 'employee' });
      }
      for (const [name, data] of Object.entries(unassignedByGroup)) {
        sections.push({ key: 'grp-' + data.groupChatId, label: name, icon: '💬', tasks: data.tasks, employeeId: null, groupChatId: data.groupChatId, groupChatName: data.groupChatName, type: 'group' });
      }
      if (unassignedNoGroup.length > 0) {
        sections.push({ key: 'unassigned', label: 'Unassigned', icon: '📌', tasks: unassignedNoGroup, employeeId: null, groupChatId: null, groupChatName: null, type: 'none' });
      }
    %>

    <% sections.forEach(section => { %>
    <div class="mb-5">
      <!-- Section header -->
      <div class="flex items-center justify-between mb-2 px-1">
        <div class="flex items-center gap-2">
          <span class="text-sm"><%= section.icon %></span>
          <span class="text-[13px] font-semibold text-zinc-700"><%= section.label %></span>
          <span class="text-[11px] text-muted bg-zinc-100 px-1.5 py-0.5 rounded-md"><%= section.tasks.length %></span>
        </div>
        <!-- Send to Telegram button -->
        <% if (section.type === 'employee' && section.employeeId) { %>
        <form method="POST" action="/tasks/send-telegram" class="inline">
          <input type="hidden" name="type" value="employee" />
          <input type="hidden" name="employee_id" value="<%= section.employeeId %>" />
          <button type="submit" class="send-btn text-[11px] text-blue-600 border border-blue-200 bg-blue-50 px-2.5 py-1 rounded-lg font-medium flex items-center gap-1" title="Send task list to <%= section.label %> on Telegram">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.665 3.717l-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785l3.019-14.228c.309-1.239-.473-1.8-1.282-1.434z"/></svg>
            Send
          </button>
        </form>
        <% } else if (section.type === 'group' && section.groupChatId) { %>
        <form method="POST" action="/tasks/send-telegram" class="inline">
          <input type="hidden" name="type" value="group" />
          <input type="hidden" name="group_chat_id" value="<%= section.groupChatId %>" />
          <button type="submit" class="send-btn text-[11px] text-blue-600 border border-blue-200 bg-blue-50 px-2.5 py-1 rounded-lg font-medium flex items-center gap-1" title="Send task list to <%= section.label %> on Telegram">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.665 3.717l-17.73 6.837c-1.21.486-1.203 1.161-.222 1.462l4.552 1.42 10.532-6.645c.498-.303.953-.14.579.192l-8.533 7.701h-.002l.002.001-.314 4.692c.46 0 .663-.211.921-.46l2.211-2.15 4.599 3.397c.848.467 1.457.227 1.668-.785l3.019-14.228c.309-1.239-.473-1.8-1.282-1.434z"/></svg>
            Send
          </button>
        </form>
        <% } %>
      </div>

      <!-- Task card -->
      <div class="bg-surface rounded-2xl border border-subtle overflow-hidden shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <% section.tasks.forEach(task => { %>
        <div class="task-row flex items-center gap-3 px-4 py-2.5 border-b border-zinc-100/80 last:border-0 pri-<%= task.priority %>">
          <!-- Checkbox -->
          <form method="POST" action="/tasks/<%= task.id %>/done" class="shrink-0">
            <button type="submit" title="Mark done"
              class="check-btn w-[18px] h-[18px] rounded-full border-[1.5px] border-zinc-300 flex items-center justify-center text-transparent text-[10px] leading-none">✓</button>
          </form>

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <p class="text-[13px] text-zinc-800 leading-snug truncate"><%= task.title %></p>
            <% if (task.due_date || task.status === 'overdue') { %>
            <div class="flex items-center gap-2 mt-0.5">
              <% if (task.due_date) { %>
              <span class="text-[11px] text-muted"><%= new Date(task.due_date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></span>
              <% } %>
              <% if (task.status === 'overdue') { %>
              <span class="text-[10px] bg-red-50 text-red-500 px-1.5 py-0.5 rounded-md font-semibold tracking-wide">OVERDUE</span>
              <% } %>
            </div>
            <% } %>
          </div>

          <!-- Priority + delete -->
          <div class="flex items-center gap-2 shrink-0">
            <div class="w-1.5 h-1.5 rounded-full dot-<%= task.priority %>" title="<%= task.priority %>"></div>
            <form method="POST" action="/tasks/<%= task.id %>/delete" class="inline hover-show"
              onsubmit="return confirm('Delete this task?')">
              <button type="submit" class="text-zinc-300 hover:text-red-400 text-[11px] transition p-0.5">✕</button>
            </form>
          </div>
        </div>
        <% }) %>

        <!-- Inline add -->
        <div class="border-t border-zinc-100/80" id="add-wrapper-<%= section.key %>">
          <button onclick="this.style.display='none'; var f=document.getElementById('add-<%= section.key %>'); f.classList.add('open'); f.querySelector('input[name=title]').focus();"
            class="w-full text-left px-4 py-2 text-[13px] text-muted hover:text-zinc-600 hover:bg-zinc-50/50 transition cursor-text">
            + Add task…
          </button>
          <form method="POST" action="/tasks/create" id="add-<%= section.key %>" class="add-row flex-col gap-2 px-4 py-3">
            <% if (section.employeeId) { %><input type="hidden" name="assigned_to" value="<%= section.employeeId %>" /><% } %>
            <% if (section.groupChatId) { %><input type="hidden" name="group_chat_id" value="<%= section.groupChatId %>" /><% } %>
            <div class="flex items-center gap-2">
              <input type="text" name="title" required placeholder="What needs to be done?"
                class="flex-1 text-[13px] border border-subtle rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-zinc-200 focus:border-zinc-300 placeholder:text-zinc-300" />
              <button type="submit"
                class="bg-accent text-white px-4 py-2 rounded-xl text-[13px] font-medium hover:bg-zinc-800 transition whitespace-nowrap">Add</button>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
              <% if (!section.employeeId) { %>
              <select name="assigned_to" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
                <option value="">Unassigned</option>
                <% employees.forEach(e => { %>
                <option value="<%= e.id %>"><%= e.name %></option>
                <% }) %>
              </select>
              <% } %>
              <select name="priority" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
                <option value="medium">Medium</option>
                <option value="high">High</option>
                <option value="low">Low</option>
              </select>
              <input type="date" name="due_date" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 text-zinc-500" />
              <% if (!section.groupChatId) { %>
              <select name="group_chat_id" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
                <option value="">No group</option>
                <% groupChats.forEach(gc => { %>
                <option value="<%= gc.group_chat_id %>"><%= gc.group_chat_name %></option>
                <% }) %>
              </select>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
    <% }) %>

    <!-- General add task -->
    <div class="mb-5">
      <div class="bg-surface rounded-2xl border border-subtle overflow-hidden shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <button onclick="this.style.display='none'; var f=document.getElementById('add-general'); f.classList.add('open'); f.querySelector('input[name=title]').focus();"
          class="w-full text-left px-4 py-3 text-[13px] text-muted hover:text-zinc-600 hover:bg-zinc-50/50 transition cursor-text">
          + Add new task…
        </button>
        <form method="POST" action="/tasks/create" id="add-general" class="add-row flex-col gap-2 px-4 py-3">
          <div class="flex items-center gap-2">
            <input type="text" name="title" required placeholder="What needs to be done?"
              class="flex-1 text-[13px] border border-subtle rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-zinc-200 focus:border-zinc-300 placeholder:text-zinc-300" />
            <button type="submit"
              class="bg-accent text-white px-4 py-2 rounded-xl text-[13px] font-medium hover:bg-zinc-800 transition whitespace-nowrap">Add</button>
          </div>
          <div class="flex items-center gap-2 flex-wrap">
            <select name="assigned_to" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
              <option value="">Unassigned</option>
              <% employees.forEach(e => { %>
              <option value="<%= e.id %>"><%= e.name %></option>
              <% }) %>
            </select>
            <select name="priority" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
              <option value="medium">Medium</option>
              <option value="high">High</option>
              <option value="low">Low</option>
            </select>
            <input type="date" name="due_date" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 text-zinc-500" />
            <select name="group_chat_id" class="text-[11px] border border-subtle rounded-lg px-2 py-1.5 bg-surface text-zinc-500">
              <option value="">No group</option>
              <% groupChats.forEach(gc => { %>
              <option value="<%= gc.group_chat_id %>"><%= gc.group_chat_name %></option>
              <% }) %>
            </select>
          </div>
        </form>
      </div>
    </div>

    <!-- Completed -->
    <% if (completedTasks.length > 0) { %>
    <div class="mb-5">
      <button onclick="var el=document.getElementById('completed-list'); el.classList.toggle('hidden'); this.querySelector('.arr').textContent = el.classList.contains('hidden') ? '›' : '‹'"
        class="flex items-center gap-1.5 text-[12px] text-muted hover:text-zinc-600 font-medium mb-2 px-1 transition">
        <span class="arr text-[10px]">›</span> Completed · <%= completedTasks.length %>
      </button>
      <div id="completed-list" class="hidden bg-surface rounded-2xl border border-subtle overflow-hidden shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        <% completedTasks.forEach(task => { %>
        <div class="task-row flex items-center gap-3 px-4 py-2 border-b border-zinc-100/80 last:border-0 opacity-40">
          <div class="w-[18px] h-[18px] rounded-full bg-emerald-500 flex items-center justify-center text-white text-[10px] shrink-0">✓</div>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] text-zinc-400 line-through truncate"><%= task.title %></p>
            <% if (task.employee_name) { %><span class="text-[11px] text-zinc-300"><%= task.employee_name %></span><% } %>
          </div>
          <form method="POST" action="/tasks/<%= task.id %>/delete" class="inline hover-show" onsubmit="return confirm('Delete?')">
            <button type="submit" class="text-zinc-300 hover:text-red-400 text-[11px] transition p-0.5">✕</button>
          </form>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% } %>

    <p class="text-center text-[11px] text-zinc-300 mt-6 mb-4">TaskToChat</p>
  </div>

</body>
</html>
