# =============================================================================
# TaskToChat - Environment Configuration
# =============================================================================

# Telegram Bot Token
# IMPORTANT: This must be a SEPARATE bot token from any other bots you run
# (e.g., OpenClaw) because Telegram only allows one active long-polling
# connection per bot token. Create a new bot via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Manager Configuration (Udit)
# The Telegram user ID of the manager who can assign tasks and receive summaries
MANAGER_TELEGRAM_ID=your_telegram_user_id_here
# The manager's name (used in logs and messages)
MANAGER_NAME=Udit
# Manager's WhatsApp number (format: 91XXXXXXXXXX, no + prefix)
MANAGER_WHATSAPP=919810000000

# Web Dashboard
# Port for the Express web server
PORT=3000

# Database
# Path to SQLite database file (relative to project root)
DB_PATH=./data/tasktochat.db

# Timezone (used for cron scheduling)
TIMEZONE=Asia/Kolkata

# Logging
# Log level: error | warn | info | debug
LOG_LEVEL=info
